{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "sure_lib",
  "description": "Developer documentation for sure_lib, a modern Lua 5.4 utility library for FiveM resources.",
  "colors": {
    "primary": "#ffffff",
    "light": "#ffffff",
    "dark": "#ffffff"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#000000",
      "dark": "#000000"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": "dark",
    "eyebrows": "breadcrumbs"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light_logo.png",
    "dark": "/logo/light_logo.png"
  },
  "navigation": {
    "directory": "card",
    "tabs": [
      {
        "tab": "sure_lib",
        "icon": "package",
        "groups": [
          {
            "group": "Start Here",
            "icon": "rocket",
            "root": "scripts/sure_lib/overview",
            "pages": [
              "scripts/sure_lib/getting-started",
              "scripts/sure_lib/module-loader"
            ]
          },
          {
            "group": "Shared Modules",
            "icon": "boxes",
            "pages": [
              "scripts/sure_lib/validator",
              "scripts/sure_lib/listener",
              "scripts/sure_lib/track",
              "scripts/sure_lib/config"
            ]
          },
          {
            "group": "Client Modules",
            "icon": "activity",
            "pages": [
              "scripts/sure_lib/player",
              "scripts/sure_lib/spawn",
              "scripts/sure_lib/lui"
            ]
          },
          {
            "group": "LUI Components",
            "icon": "panels-top-left",
            "pages": [
              {
                "group": "Primitives",
                "icon": "type",
                "pages": [
                  "scripts/sure_lib/lui/primitives/text"
                ]
              },
              {
                "group": "Controls",
                "icon": "sliders-horizontal",
                "pages": [
                  "scripts/sure_lib/lui/controls/button",
                  "scripts/sure_lib/lui/controls/input",
                  "scripts/sure_lib/lui/controls/select",
                  "scripts/sure_lib/lui/controls/slider",
                  "scripts/sure_lib/lui/controls/textarea"
                ]
              },
              {
                "group": "Display",
                "icon": "badge-info",
                "pages": [
                  "scripts/sure_lib/lui/display/accordion",
                  "scripts/sure_lib/lui/display/alert",
                  "scripts/sure_lib/lui/display/badge",
                  "scripts/sure_lib/lui/display/table",
                  "scripts/sure_lib/lui/display/typography"
                ]
              },
              {
                "group": "Layout",
                "icon": "layout-panel-top",
                "pages": [
                  "scripts/sure_lib/lui/layout/panel",
                  "scripts/sure_lib/lui/layout/row",
                  "scripts/sure_lib/lui/layout/stack"
                ]
              },
              {
                "group": "Motion",
                "icon": "sparkles",
                "pages": [
                  "scripts/sure_lib/lui/motion/motion-node",
                  "scripts/sure_lib/lui/motion/presence"
                ]
              },
              {
                "group": "Navigation",
                "icon": "panel-top",
                "pages": [
                  "scripts/sure_lib/lui/navigation/carousel",
                  "scripts/sure_lib/lui/navigation/tabs"
                ]
              },
              {
                "group": "Overlay",
                "icon": "message-square",
                "pages": [
                  "scripts/sure_lib/lui/overlay/tooltip"
                ]
              }
            ]
          },
          {
            "group": "Server Modules",
            "icon": "database",
            "pages": [
              "scripts/sure_lib/cooldown",
              "scripts/sure_lib/db",
              "scripts/sure_lib/esx"
            ]
          },
          {
            "group": "Reference",
            "icon": "list-check",
            "pages": [
              "scripts/sure_lib/api-reference"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Sure-Development/sure_lib",
          "icon": "github"
        },
        {
          "anchor": "Support",
          "href": "mailto:fx.frame009@gmail.com",
          "icon": "mail"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/Sure-Development/sure_lib"
      },
      {
        "label": "Support",
        "href": "mailto:fx.frame009@gmail.com",
        "icon": "mail"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get sure_lib",
      "href": "https://github.com/Sure-Development/sure_lib"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Sure-Development"
    },
    "links": [
      {
        "header": "sure_lib",
        "items": [
          {
            "label": "Overview",
            "href": "/scripts/sure_lib/overview"
          },
          {
            "label": "API Reference",
            "href": "/scripts/sure_lib/api-reference"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"],
    "display": "toc"
  }
}
